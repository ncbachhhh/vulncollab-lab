# VulnCollab Lab local development values.
# These values are fake lab defaults. Do not use them for a real deployment.

SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080

MYSQL_DATABASE=vulncollab
MYSQL_USER=vulncollab
MYSQL_PASSWORD=vulncollab_dev_password
MYSQL_ROOT_PASSWORD=vulncollab_root_password
MYSQL_PORT=3306

DB_URL=jdbc:mysql://localhost:3306/vulncollab?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=vulncollab
DB_PASSWORD=vulncollab_dev_password

REDIS_HOST=localhost
REDIS_PORT=6379

MAIL_HOST=localhost
MAIL_PORT=1025
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

APP_VULNERABLE_MODE=true
APP_PUBLIC_DOMAIN=lab.example.com
APP_LAB_WARNING_ENABLED=true
APP_CHALLENGE_SUBMIT_ENABLED=true
APP_SECURE_MODE_BANNER_ENABLED=true

JWT_SECRET=secret123
JWT_ACCESS_TOKEN_EXPIRATION_MS=3600000
JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000

UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE=5MB

CORS_MODE=vulnerable-or-secure
DEPLOYMENT_ENVIRONMENT=local
DEPLOYMENT_EXPOSE_VULNERABLE_LAB=false
